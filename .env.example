# ---------------------------------------------------------------------------
# Admin panel authentication
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local development, and set the SAME two
# variables in your Vercel project (Settings -> Environment Variables) for
# production. Never commit real values.

# The password you'll type on the /admin login screen. Use something long and
# unique (a passphrase or a password-manager-generated string).
ADMIN_PASSWORD="change-me-to-a-long-strong-password"

# A long random string used to sign the login session cookie. Generate one with:
#   openssl rand -base64 32
# Changing this value immediately signs everyone out.
ADMIN_SESSION_SECRET="change-me-to-a-long-random-secret"
