# ---------------------------------------------------------------------------
# Admin panel authentication
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local development, and set the SAME two
# variables in your Vercel project (Settings -> Environment Variables) for
# production. Never commit real values.

# The password you'll type on the /admin login screen. Use something long and
# unique (a passphrase or a password-manager-generated string).
ADMIN_PASSWORD="change-me-to-a-long-strong-password"

# A long random string used to sign the login session cookie. Generate one with:
#   openssl rand -base64 32
# Changing this value immediately signs everyone out.
ADMIN_SESSION_SECRET="change-me-to-a-long-random-secret"

# Secret "access key" that makes the /admin area visible at all. Visit
# /admin?key=THIS_VALUE once to reveal the login screen; anyone without it just
# gets a 404 (the admin area appears not to exist). Use a long, URL-safe string
# (letters/numbers/dashes). If left unset, the login screen is simply visible to
# anyone (still password-protected).
ADMIN_ACCESS_KEY="change-me-to-a-long-url-safe-key"


# ---------------------------------------------------------------------------
# Firebase customer authentication (Google + email/password)
# ---------------------------------------------------------------------------
# These come from your Firebase project: Console -> Project settings -> "Your
# apps" -> Web app -> SDK setup and configuration (the firebaseConfig object).
# NOTE: NEXT_PUBLIC_ values are exposed to the browser by design — Firebase web
# config is public and safe to expose. Real protection comes from Firebase
# Authorized Domains + security rules. Set the SAME values in Vercel.
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="000000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:abcdef123456"


# ---------------------------------------------------------------------------
# Firebase Admin (server-side) — lets the /admin panel manage customer projects
# ---------------------------------------------------------------------------
# This is a SECRET (do NOT prefix with NEXT_PUBLIC). Get it from Firebase
# Console -> Project settings -> Service accounts -> Generate new private key.
# Paste the ENTIRE downloaded JSON file as the value (one line is fine).
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}'


# ---------------------------------------------------------------------------
# Email notifications (Gmail App Password) — owner alerts + support inbox
# ---------------------------------------------------------------------------
# The business Gmail that SENDS the notifications, and a Gmail "App Password"
# (Google Account -> Security -> 2-Step Verification -> App passwords).
# Notifications are sent to the owner emails listed in lib/admin.ts.
GMAIL_USER="your-business-gmail@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"
