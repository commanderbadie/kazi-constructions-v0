rules_version = '2';

// Security rules for the Kazi Constructions customer portal.
// Paste these in: Firebase Console -> Build -> Firestore Database -> Rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Enquiries: a signed-in customer may create enquiries tagged with their
    // own uid, and read only their own. No edits/deletes from the client.
    match /enquiries/{enquiryId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // The owner/admin is identified by their verified email.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == "badieuddinkazi@gmail.com";
    }

    // Projects: the owner can create/update/delete any project. A customer can
    // read only the projects assigned to their email.
    match /projects/{projectId} {
      allow read: if isAdmin()
        || (request.auth != null
            && resource.data.customerEmail == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }

    // Documents/quotes (shared as links): same access model as projects.
    match /documents/{docId} {
      allow read: if isAdmin()
        || (request.auth != null
            && resource.data.customerEmail == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }

    // Everything else is locked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
