rules_version = '2';

// Security rules for the Kazi Constructions customer portal.
// Paste these in: Firebase Console -> Build -> Firestore Database -> Rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Enquiries: a signed-in customer may create enquiries tagged with their
    // own uid, and read only their own. No edits/deletes from the client.
    match /enquiries/{enquiryId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Everything else is locked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
